// ============================================================
// JETSCHOOL ACADEMY — Skema Database (MySQL)
// Alur: Registration → Payment (Xendit) → TestAttempt → Certificate
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// Jenis program — menentukan alur pembelian
enum ProgramType {
  WEBINAR // gratis ikut; sertifikat berbayar (tripwire)
  KELAS // kelas online / LMS berbayar
  WORKSHOP // sesi live praktik berbayar
  BOOTCAMP // program intensif multi-sesi berbayar
}

// Kriteria kelulusan program — menentukan kapan sertifikat terbit.
// Tidak ada post-test terpisah: tes = materi kuis yang bisa ditaruh di mana pun dalam kurikulum.
enum CompletionCriteria {
  ALL_LESSONS // penyelesaian modul: semua materi selesai (kuis harus lulus agar selesai)
  ALL_QUIZZES // hasil tes: semua kuis dalam kurikulum lulus (materi non-kuis tidak wajib)
}

// Jenis sertifikat yang diterbitkan program
enum CertKind {
  PARTICIPATION // Sertifikat Keikutsertaan — bukti ikut/hadir, tanpa syarat lulus
  COMPLETION // Sertifikat Penyelesaian — menyelesaikan seluruh materi
  ACHIEVEMENT // Sertifikat Kelulusan — lulus penilaian/post-test
}

// Tipe konten materi pembelajaran
enum LessonType {
  VIDEO // embed YouTube / Vimeo
  TEXT // artikel / teks materi
  PDF // dokumen PDF (upload / URL)
  QUIZ // kuis pilihan ganda per materi
}

// Jenis jawaban kuis
enum AnswerKey {
  A
  B
  C
  D
}

// Program pelatihan
model Program {
  id                 String             @id @default(cuid())
  slug               String             @unique // dipakai di URL: /program/digital-marketing-pemula
  type               ProgramType        @default(WEBINAR)
  title              String
  tagline            String             @db.Text // headline penjualan yang spesifik (hasil akhir, bukan ilmu)
  description        String             @db.Text
  emoji              String             @default("🎓")
  imageUrl           String?
  mentorName         String
  mentorBio          String             @db.Text
  materi             Json // array string: poin "apa yang akan dipelajari"
  deliverables       Json // value stack: array { label, value } — "yang kamu bawa pulang"
  guarantee          String?            @db.Text // teks garansi / risk reversal
  contentBlocks      Json? // editor blok halaman (teks/gambar/video/dll) — jika terisi, GANTIKAN tampilan body lama (description/materi/deliverables/guarantee) di halaman publik
  scheduleAt         DateTime // jadwal mulai (webinar/workshop/bootcamp) atau tanggal akses (kelas)
  durationLabel      String             @default("2 jam") // "2 jam", "4 minggu", "6 sesi live"
  zoomLink           String? // dikirim via WA setelah daftar/bayar
  waGroupLink        String? // link grup WhatsApp peserta
  lmsLink            String? // link akses LMS (kelas/bonus) — dikirim via WA
  price              Int                @default(0) // harga program (Rp). 0 = gratis (webinar)
  priceOld           Int? // harga coret program
  certPrice          Int                @default(49000) // WEBINAR saja: harga paket sertifikat (tripwire)
  certPriceOld       Int? // harga coret paket sertifikat
  seatsLeft          Int? // sisa kursi utk scarcity (opsional, tampil jika diisi)
  passingScore       Int                @default(60) // skor minimal lulus post-test (0-100)
  completionCriteria CompletionCriteria @default(ALL_LESSONS) // syarat sertifikat terbit
  certKind           CertKind           @default(ACHIEVEMENT) // jenis sertifikat yang terbit
  maxTestAttempts    Int                @default(0) // 0 = tak terbatas; >0 = batas percobaan per kuis
  isActive           Boolean            @default(true)
  certClaimOpen      Boolean            @default(false) // admin buka/tutup klaim sertifikat secara manual
  isFeatured         Boolean            @default(false)
  certBgUrl          String?            @db.Text
  certConfig         Json?
  questions          Question[]
  registrations      Registration[]
  modules            LmsModule[]
  groups             LmsGroup[]
  batches            ProgramBatch[]
  categoryId         String?
  category           Category?          @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@index([categoryId])
  @@map("program")
}

// Jadwal berulang (angkatan/batch) untuk satu program. Program tetap satu
// (kurikulum, materi, harga sama) — batch cuma beda tanggal mulai & kuota.
// Program.scheduleAt tetap dipakai sebagai fallback jika program belum
// punya batch (program non-berulang, perilaku lama tidak berubah).
model ProgramBatch {
  id            String         @id @default(cuid())
  program       Program        @relation(fields: [programId], references: [id], onDelete: Cascade)
  programId     String
  scheduleAt    DateTime
  seatsLeft     Int? // sisa kursi khusus batch ini (opsional)
  isActive      Boolean        @default(true) // nonaktifkan tanpa hapus (histori pendaftaran tetap utuh)
  registrations Registration[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([programId])
  @@index([programId, scheduleAt])
  @@index([scheduleAt])
  @@map("programbatch")
}

// Pendaftar webinar (leads dari iklan Meta)
model Registration {
  id           String             @id @default(cuid())
  userId       String?
  user         User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  name         String // nama lengkap — dipakai di sertifikat
  whatsapp     String // format 08xxx, dinormalisasi ke 628xxx saat kirim WA
  email        String
  institution  String? // asal lembaga / instansi
  program      Program            @relation(fields: [programId], references: [id])
  programId    String
  batch        ProgramBatch?      @relation(fields: [batchId], references: [id], onDelete: SetNull)
  batchId      String? // batch/angkatan yang dipilih peserta (null = program tanpa batch, pakai Program.scheduleAt)
  status       RegistrationStatus @default(REGISTERED)
  participants Json? // array string: nama peserta tambahan (multi-pendaftar 1 group WA/email)
  payment      Payment?
  attempts     TestAttempt[]
  certificate  Certificate?
  completions  Completion[]
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@unique([whatsapp, programId]) // satu nomor WA = satu pendaftaran per program
  @@index([email])
  @@index([email, programId]) // login lookup lebih efisien
  @@index([whatsapp]) // lookup WA saja (OTP login)
  @@index([programId])
  @@index([batchId])
  @@index([status])
  @@index([status, programId]) // filter status per program di dashboard
  @@index([createdAt])
  @@index([userId])
  @@map("registration")
}

enum RegistrationStatus {
  REGISTERED // sudah daftar webinar gratis
  PAID // sudah bayar paket sertifikat, boleh post-test
  PASSED // lulus post-test, sertifikat terbit
  EXPIRED // pembayaran kadaluarsa
  FAILED // pembayaran gagal
  CANCELLED // dibatalkan
  REFUNDED // sudah bayar lalu direfund admin — akses dicabut kembali
}

// Pembayaran paket sertifikat via Xendit Invoice
model Payment {
  id                  String               @id @default(cuid())
  registration        Registration         @relation(fields: [registrationId], references: [id])
  registrationId      String               @unique
  xenditInvoiceId     String?              @unique // id invoice dari Xendit
  invoiceUrl          String?              @db.Text // checkout URL Xendit
  amount              Int
  status              PaymentStatus        @default(PENDING)
  paidAt              DateTime?
  originalAmount      Int? // harga sebelum diskon (null = tidak ada diskon dipakai)
  discountAmount      Int                  @default(0)
  voucher             Voucher?             @relation(fields: [voucherId], references: [id], onDelete: SetNull)
  voucherId           String?
  refundedAt          DateTime?
  refundAmount        Int? // jumlah dana yang dikembalikan (dicatat manual oleh admin)
  refundReason        String?              @db.Text
  // Affiliate yang mereferensikan transaksi ini (diisi saat checkout/registrasi jika kode/ref valid).
  // AffiliateConversion baru DIBUAT saat status berubah jadi PAID — bukan di sini — supaya invoice
  // yang tidak pernah lunas tidak meninggalkan jejak komisi palsu.
  affiliate           Affiliate?           @relation(fields: [affiliateId], references: [id], onDelete: SetNull)
  affiliateId         String?
  affiliateConversion AffiliateConversion?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@index([status])
  @@index([voucherId])
  @@index([affiliateId])
  @@map("payment")
}

enum PaymentStatus {
  PENDING
  PAID
  EXPIRED
  FAILED
  REFUNDED
}

enum VoucherType {
  PERCENT // potongan persentase dari harga
  FIXED // potongan nominal Rupiah tetap
}

// Kode voucher/diskon — berlaku global untuk checkout program berbayar & paket sertifikat webinar
model Voucher {
  id          String      @id @default(cuid())
  code        String      @unique // disimpan huruf besar, mis. "DISKON20"
  type        VoucherType @default(PERCENT)
  value       Int // PERCENT: 1-100 | FIXED: nominal Rupiah
  maxDiscount Int? // cap potongan Rupiah utk tipe PERCENT (opsional)
  maxUses     Int? // null = tak terbatas
  usedCount   Int         @default(0)
  isActive    Boolean     @default(true)
  validFrom   DateTime?
  validUntil  DateTime?
  payments    Payment[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([isActive])
  @@map("voucher")
}

// Soal pilihan ganda — post-test program (lessonId null) atau kuis materi (lessonId terisi)
model Question {
  id        String    @id @default(cuid())
  program   Program   @relation(fields: [programId], references: [id], onDelete: Cascade)
  programId String
  lesson    Lesson?   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  lessonId  String?
  text      String    @db.Text
  optionA   String
  optionB   String
  optionC   String
  optionD   String
  correct   AnswerKey
  order     Int       @default(0)

  @@index([programId])
  @@index([lessonId])
  @@map("question")
}

// Riwayat pengerjaan post-test (lessonId null) atau kuis materi (lessonId terisi)
model TestAttempt {
  id             String       @id @default(cuid())
  registration   Registration @relation(fields: [registrationId], references: [id])
  registrationId String
  lessonId       String? // null = post-test program
  score          Int // 0-100
  passed         Boolean
  createdAt      DateTime     @default(now())

  @@index([registrationId])
  @@index([registrationId, lessonId])
  @@index([lessonId]) // untuk agregasi hasil kuis per materi
  @@index([passed, registrationId]) // cek apakah sudah pernah lulus
  @@map("testattempt")
}

// Sertifikat — terbit otomatis saat lulus post-test
model Certificate {
  id             String       @id @default(cuid())
  number         String       @unique // format: JSA-2026-XXXXXXXX (8 random hex) — utk verifikasi publik
  registration   Registration @relation(fields: [registrationId], references: [id])
  registrationId String       @unique
  issuedAt       DateTime     @default(now())

  @@index([issuedAt])
  @@map("certificate")
}

// Sakelar global — satu baris (singleton, id tetap "singleton"). Dipakai utk menghentikan
// sementara PENERBITAN sertifikat baru di seluruh situs (mis. sedang ada bug/lagi diuji),
// tanpa mengubah kode. Sertifikat yang SUDAH terbit tidak terpengaruh.
model SystemSetting {
  id                  String   @id @default("singleton")
  certIssuanceEnabled Boolean  @default(true)
  updatedAt           DateTime @updatedAt

  @@map("systemsetting")
}

// Kelompok modul — jenjang teratas kurikulum (mis. "Bagian 1: Dasar-dasar")
model LmsGroup {
  id        String      @id @default(cuid())
  program   Program     @relation(fields: [programId], references: [id], onDelete: Cascade)
  programId String
  title     String
  order     Int         @default(0)
  modules   LmsModule[]

  @@index([programId])
  @@map("lmsgroup")
}

// Modul / sub-bab — berisi materi; bisa berdiri sendiri atau di dalam kelompok
model LmsModule {
  id        String    @id @default(cuid())
  program   Program   @relation(fields: [programId], references: [id], onDelete: Cascade)
  programId String
  group     LmsGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)
  groupId   String?
  title     String
  order     Int       @default(0)
  lessons   Lesson[]

  @@index([programId])
  @@index([groupId])
  @@map("lmsmodule")
}

// LMS Lessons (Materi pembelajaran: video / teks / PDF / kuis)
model Lesson {
  id           String       @id @default(cuid())
  module       LmsModule    @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  moduleId     String
  title        String
  type         LessonType   @default(VIDEO)
  videoUrl     String? // URL Video YouTube / Vimeo
  fileUrl      String?      @db.Text // URL PDF (upload atau eksternal)
  content      String?      @db.Text // Teks materi pembelajaran
  duration     String       @default("10 menit") // Durasi materi
  passingScore Int? // khusus QUIZ: skor minimal lulus (null = pakai passingScore program)
  isPreview    Boolean      @default(false) // materi bisa diakses gratis sebagai preview
  order        Int          @default(0)
  questions    Question[] // soal kuis (khusus type QUIZ)
  completions  Completion[]

  @@index([moduleId])
  @@map("lesson")
}

// LMS Completions (Status selesai pengerjaan materi oleh peserta)
model Completion {
  id             String       @id @default(cuid())
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  registrationId String
  lesson         Lesson       @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  lessonId       String
  completedAt    DateTime     @default(now())

  @@unique([registrationId, lessonId])
  @@index([registrationId])
  @@index([lessonId])
  @@index([lessonId, registrationId]) // agregasi completion per pelajaran
  @@map("completion")
}

// OTP untuk login member — dikirim via WhatsApp, berlaku 5 menit
model OtpCode {
  id         String   @id @default(cuid())
  identifier String // whatsapp atau email — yang dipakai untuk login
  code       String // 6 digit angka
  used       Boolean  @default(false)
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@index([identifier])
  @@index([identifier, code]) // verifikasi OTP
  @@index([expiresAt]) // cleanup job: hapus OTP kedaluwarsa
  @@index([used, expiresAt]) // hapus OTP lama yang tidak terpakai
  @@map("otpcode")
}

// Kategori program
model Category {
  id         String    @id @default(cuid())
  slug       String    @unique
  name       String
  isFeatured Boolean   @default(false)
  programs   Program[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@map("category")
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
}

model User {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  whatsapp      String?        @unique
  institution   String?
  passwordHash  String? // Kata sandi terenkripsi (untuk ADMIN / TEACHER / STUDENT)
  role          Role           @default(STUDENT)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  registrations Registration[]
  affiliate     Affiliate?

  @@index([role]) // filter by role di halaman user management
  @@index([createdAt]) // sort terbaru di daftar user
  @@map("user")
}

// API key untuk integrasi mesin-ke-mesin (mis. Hermes agent marketing) —
// bukan untuk login manusia. Dicek via header X-API-Key di /api/v1/*.
model ApiKey {
  id         String    @id @default(cuid())
  label      String    @default("Hermes Agent Marketing")
  key        String    @unique
  isActive   Boolean   @default(true)
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([key])
  @@map("apikey")
}

// ============================================================
// AFFILIATE — program afiliasi alumni: admin mengundang user
// terpilih, tiap affiliate bisa punya komisi & diskon pelanggan
// sendiri-sendiri, penarikan dana via Xendit Payout, dan tiket
// dukungan dari affiliate/pengguna.
// ============================================================

enum AffiliateStatus {
  PENDING // diundang admin, menunggu respons user
  ACTIVE // diterima & aktif mempromosikan
  SUSPENDED // dinonaktifkan sementara oleh admin (kode berhenti berfungsi)
  REJECTED // user menolak undangan
}

enum ConversionStatus {
  PENDING // transaksi tercatat, menunggu masa tahan (hold) sebelum bisa dicairkan
  AVAILABLE // masa tahan lewat, bisa dicairkan
  WITHDRAWN // sudah termasuk dalam penarikan yang selesai
  VOIDED // dibatalkan (pembayaran induk direfund)
}

enum WithdrawalStatus {
  REQUESTED // affiliate mengajukan penarikan
  PROCESSING // admin sudah memicu payout Xendit, menunggu konfirmasi
  COMPLETED // dana sudah diterima (dikonfirmasi Xendit atau manual oleh admin)
  REJECTED // ditolak admin sebelum diproses
  FAILED // payout Xendit gagal
}

enum TicketCategory {
  KOMISI
  PENARIKAN
  AKUN
  TEKNIS
  LAINNYA
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketSenderRole {
  USER
  ADMIN
}

// Profil affiliate — satu per User. Dibuat admin saat mengirim "tombol penawaran";
// baru aktif (bisa dipakai kodenya) setelah user menerima undangan.
model Affiliate {
  id                String                @id @default(cuid())
  user              User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId            String                @unique
  code              String                @unique // kode referral custom, dipakai di /?ref=KODE
  status            AffiliateStatus       @default(PENDING)
  commissionType    VoucherType           @default(PERCENT) // basis komisi affiliate per transaksi
  commissionValue   Int                   @default(10) // PERCENT: 1-100 | FIXED: nominal Rupiah
  discountType      VoucherType           @default(PERCENT) // basis diskon utk pembeli yang pakai kode ini
  discountValue     Int                   @default(0) // 0 = tidak ada diskon customer, hanya komisi
  bankName          String?
  bankAccountNumber String?
  bankAccountName   String?
  ewalletChannel    String? // kode channel Xendit Payout, mis. "ID_OVO", "ID_DANA"
  ewalletNumber     String?
  clickCount        Int                   @default(0) // hitungan kunjungan lewat link referral (analitik kasar)
  invitedAt         DateTime              @default(now())
  invitedBy         String? // nama/email admin yang mengundang
  respondedAt       DateTime?
  adminNote         String?               @db.Text
  conversions       AffiliateConversion[]
  withdrawals       AffiliateWithdrawal[]
  tickets           Ticket[]
  payments          Payment[]
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  @@index([status])
  @@map("affiliate")
}

// Catatan komisi per transaksi (ledger) — satu baris per Payment yang memakai kode affiliate.
model AffiliateConversion {
  id                     String           @id @default(cuid())
  affiliate              Affiliate        @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  affiliateId            String
  payment                Payment          @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  paymentId              String           @unique
  registrationId         String
  saleAmount             Int // nominal yang benar-benar dibayar customer (setelah diskon affiliate)
  discountGiven          Int              @default(0) // potongan yang customer terima karena kode ini
  commissionAmount       Int
  commissionTypeSnapshot VoucherType // salinan tipe komisi affiliate saat transaksi terjadi
  commissionRateSnapshot Int // salinan nilai komisi affiliate saat transaksi terjadi
  status                 ConversionStatus @default(PENDING)
  availableAt            DateTime? // kapan boleh dicairkan (createdAt + holdDays pengaturan)
  voidedAt               DateTime?
  voidReason             String?          @db.Text
  createdAt              DateTime         @default(now())

  @@index([affiliateId])
  @@index([status])
  @@index([affiliateId, status])
  @@map("affiliateconversion")
}

// Pengajuan penarikan komisi affiliate — diproses admin via Xendit Payout.
model AffiliateWithdrawal {
  id                String           @id @default(cuid())
  affiliate         Affiliate        @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  affiliateId       String
  amount            Int
  channelCode       String // kode channel Xendit Payout, mis. "ID_BCA", "ID_OVO"
  accountNumber     String
  accountHolderName String
  status            WithdrawalStatus @default(REQUESTED)
  xenditPayoutId    String?          @unique
  xenditReferenceId String?          @unique
  failureReason     String?          @db.Text
  adminNote         String?          @db.Text
  requestedAt       DateTime         @default(now())
  processedAt       DateTime?
  processedBy       String?

  @@index([affiliateId])
  @@index([status])
  @@map("affiliatewithdrawal")
}

// Pengaturan global program affiliate — satu baris (singleton, id tetap "singleton").
model AffiliateSettings {
  id                     String      @id @default("singleton")
  defaultCommissionType  VoucherType @default(PERCENT)
  defaultCommissionValue Int         @default(10)
  defaultDiscountType    VoucherType @default(PERCENT)
  defaultDiscountValue   Int         @default(5)
  minWithdrawal          Int         @default(100000) // nominal minimal sekali penarikan (Rp)
  holdDays               Int         @default(7) // masa tahan komisi sebelum bisa dicairkan (buffer refund/fraud)
  cookieDays             Int         @default(30) // masa berlaku atribusi ?ref= di cookie pengunjung
  termsText              String?     @db.Text // syarat & ketentuan program affiliate, ditampilkan di dashboard member
  updatedAt              DateTime    @updatedAt

  @@map("affiliatesettings")
}

// Tiket dukungan — dari affiliate (soal komisi/penarikan) maupun pengguna umum.
model Ticket {
  id          String          @id @default(cuid())
  affiliate   Affiliate?      @relation(fields: [affiliateId], references: [id], onDelete: SetNull)
  affiliateId String?
  name        String
  email       String
  whatsapp    String?
  subject     String
  category    TicketCategory  @default(LAINNYA)
  status      TicketStatus    @default(OPEN)
  messages    TicketMessage[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([affiliateId])
  @@index([status])
  @@map("ticket")
}

model TicketMessage {
  id         String           @id @default(cuid())
  ticket     Ticket           @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  ticketId   String
  senderRole TicketSenderRole
  senderName String
  message    String           @db.Text
  createdAt  DateTime         @default(now())

  @@index([ticketId])
  @@map("ticketmessage")
}

// Artikel blog — konten SEO, tidak tampil di beranda, hanya lewat menu & /artikel.
model Article {
  id            String    @id @default(cuid())
  slug          String    @unique
  title         String
  excerpt       String    @db.Text // ringkasan — dipakai di kartu daftar & meta description SEO
  content       String    @db.Text // HTML dari rich text editor, disanitasi sebelum simpan
  coverImageUrl String?   @db.Text
  authorName    String    @default("Tim Jetschool Academy")
  isPublished   Boolean   @default(false)
  publishedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([isPublished, publishedAt])
  @@map("article")
}
