// ============================================================
// JETSCHOOL ACADEMY — Skema Database (MySQL)
// Alur: Registration → Payment (Xendit) → TestAttempt → Certificate
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// Jenis program — menentukan alur pembelian
enum ProgramType {
  WEBINAR // gratis ikut; sertifikat berbayar (tripwire)
  KELAS // kelas online / LMS berbayar
  WORKSHOP // sesi live praktik berbayar
  BOOTCAMP // program intensif multi-sesi berbayar
}

// Kriteria kelulusan program — menentukan kapan sertifikat terbit.
// Tidak ada post-test terpisah: tes = materi kuis yang bisa ditaruh di mana pun dalam kurikulum.
enum CompletionCriteria {
  ALL_LESSONS // penyelesaian modul: semua materi selesai (kuis harus lulus agar selesai)
  ALL_QUIZZES // hasil tes: semua kuis dalam kurikulum lulus (materi non-kuis tidak wajib)
}

// Jenis sertifikat yang diterbitkan program
enum CertKind {
  PARTICIPATION // Sertifikat Keikutsertaan — bukti ikut/hadir, tanpa syarat lulus
  COMPLETION // Sertifikat Penyelesaian — menyelesaikan seluruh materi
  ACHIEVEMENT // Sertifikat Kelulusan — lulus penilaian/post-test
}

// Tipe konten materi pembelajaran
enum LessonType {
  VIDEO // embed YouTube / Vimeo
  TEXT // artikel / teks materi
  PDF // dokumen PDF (upload / URL)
  QUIZ // kuis pilihan ganda per materi
}

// Jenis jawaban kuis
enum AnswerKey {
  A
  B
  C
  D
}

// Program pelatihan
model Program {
  id                 String             @id @default(cuid())
  slug               String             @unique // dipakai di URL: /program/digital-marketing-pemula
  type               ProgramType        @default(WEBINAR)
  title              String
  tagline            String             @db.Text // headline penjualan yang spesifik (hasil akhir, bukan ilmu)
  description        String             @db.Text
  emoji              String             @default("🎓")
  imageUrl           String?
  mentorName         String
  mentorBio          String             @db.Text
  materi             Json // array string: poin "apa yang akan dipelajari"
  deliverables       Json // value stack: array { label, value } — "yang kamu bawa pulang"
  guarantee          String?            @db.Text // teks garansi / risk reversal
  contentBlocks      Json? // editor blok halaman (teks/gambar/video/dll) — jika terisi, GANTIKAN tampilan body lama (description/materi/deliverables/guarantee) di halaman publik
  scheduleAt         DateTime // jadwal mulai (webinar/workshop/bootcamp) atau tanggal akses (kelas)
  durationLabel      String             @default("2 jam") // "2 jam", "4 minggu", "6 sesi live"
  zoomLink           String? // dikirim via WA setelah daftar/bayar
  waGroupLink        String? // link grup WhatsApp peserta
  lmsLink            String? // link akses LMS (kelas/bonus) — dikirim via WA
  price              Int                @default(0) // harga program (Rp). 0 = gratis (webinar)
  priceOld           Int? // harga coret program
  certPrice          Int                @default(49000) // WEBINAR saja: harga paket sertifikat (tripwire)
  certPriceOld       Int? // harga coret paket sertifikat
  seatsLeft          Int? // sisa kursi utk scarcity (opsional, tampil jika diisi)
  passingScore       Int                @default(60) // skor minimal lulus post-test (0-100)
  completionCriteria CompletionCriteria @default(ALL_LESSONS) // syarat sertifikat terbit
  certKind           CertKind           @default(ACHIEVEMENT) // jenis sertifikat yang terbit
  maxTestAttempts    Int                @default(0) // 0 = tak terbatas; >0 = batas percobaan per kuis
  isActive           Boolean            @default(true)
  certClaimOpen      Boolean            @default(false) // admin buka/tutup klaim sertifikat secara manual
  isFeatured         Boolean            @default(false)
  certBgUrl          String?            @db.Text
  certConfig         Json?
  questions          Question[]
  registrations      Registration[]
  modules            LmsModule[]
  groups             LmsGroup[]
  batches            ProgramBatch[]
  categoryId         String?
  category           Category?          @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@index([categoryId])
  @@map("program")
}

// Jadwal berulang (angkatan/batch) untuk satu program. Program tetap satu
// (kurikulum, materi, harga sama) — batch cuma beda tanggal mulai & kuota.
// Program.scheduleAt tetap dipakai sebagai fallback jika program belum
// punya batch (program non-berulang, perilaku lama tidak berubah).
model ProgramBatch {
  id            String         @id @default(cuid())
  program       Program        @relation(fields: [programId], references: [id], onDelete: Cascade)
  programId     String
  scheduleAt    DateTime
  seatsLeft     Int? // sisa kursi khusus batch ini (opsional)
  isActive      Boolean        @default(true) // nonaktifkan tanpa hapus (histori pendaftaran tetap utuh)
  registrations Registration[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([programId])
  @@index([programId, scheduleAt])
  @@index([scheduleAt])
  @@map("programbatch")
}

// Pendaftar webinar (leads dari iklan Meta)
model Registration {
  id          String             @id @default(cuid())
  userId      String?
  user        User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  name        String // nama lengkap — dipakai di sertifikat
  whatsapp    String // format 08xxx, dinormalisasi ke 628xxx saat kirim WA
  email       String
  institution String? // asal lembaga / instansi
  program     Program            @relation(fields: [programId], references: [id])
  programId   String
  batch       ProgramBatch?      @relation(fields: [batchId], references: [id], onDelete: SetNull)
  batchId     String? // batch/angkatan yang dipilih peserta (null = program tanpa batch, pakai Program.scheduleAt)
  status      RegistrationStatus @default(REGISTERED)
  payment     Payment?
  attempts    TestAttempt[]
  certificate Certificate?
  completions Completion[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@unique([whatsapp, programId]) // satu nomor WA = satu pendaftaran per program
  @@index([email])
  @@index([email, programId]) // login lookup lebih efisien
  @@index([whatsapp]) // lookup WA saja (OTP login)
  @@index([programId])
  @@index([batchId])
  @@index([status])
  @@index([status, programId]) // filter status per program di dashboard
  @@index([createdAt])
  @@index([userId])
  @@map("registration")
}

enum RegistrationStatus {
  REGISTERED // sudah daftar webinar gratis
  PAID // sudah bayar paket sertifikat, boleh post-test
  PASSED // lulus post-test, sertifikat terbit
  EXPIRED // pembayaran kadaluarsa
  FAILED // pembayaran gagal
  CANCELLED // dibatalkan
}

// Pembayaran paket sertifikat via Xendit Invoice
model Payment {
  id              String        @id @default(cuid())
  registration    Registration  @relation(fields: [registrationId], references: [id])
  registrationId  String        @unique
  xenditInvoiceId String?       @unique // id invoice dari Xendit
  invoiceUrl      String?       @db.Text // checkout URL Xendit
  amount          Int
  status          PaymentStatus @default(PENDING)
  paidAt          DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([status])
  @@map("payment")
}

enum PaymentStatus {
  PENDING
  PAID
  EXPIRED
  FAILED
}

// Soal pilihan ganda — post-test program (lessonId null) atau kuis materi (lessonId terisi)
model Question {
  id        String    @id @default(cuid())
  program   Program   @relation(fields: [programId], references: [id], onDelete: Cascade)
  programId String
  lesson    Lesson?   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  lessonId  String?
  text      String    @db.Text
  optionA   String
  optionB   String
  optionC   String
  optionD   String
  correct   AnswerKey
  order     Int       @default(0)

  @@index([programId])
  @@index([lessonId])
  @@map("question")
}

// Riwayat pengerjaan post-test (lessonId null) atau kuis materi (lessonId terisi)
model TestAttempt {
  id             String       @id @default(cuid())
  registration   Registration @relation(fields: [registrationId], references: [id])
  registrationId String
  lessonId       String? // null = post-test program
  score          Int // 0-100
  passed         Boolean
  createdAt      DateTime     @default(now())

  @@index([registrationId])
  @@index([registrationId, lessonId])
  @@index([lessonId]) // untuk agregasi hasil kuis per materi
  @@index([passed, registrationId]) // cek apakah sudah pernah lulus
  @@map("testattempt")
}

// Sertifikat — terbit otomatis saat lulus post-test
model Certificate {
  id             String       @id @default(cuid())
  number         String       @unique // format: JSA-2026-XXXXXXXX (8 random hex) — utk verifikasi publik
  registration   Registration @relation(fields: [registrationId], references: [id])
  registrationId String       @unique
  issuedAt       DateTime     @default(now())

  @@index([issuedAt])
  @@map("certificate")
}

// Kelompok modul — jenjang teratas kurikulum (mis. "Bagian 1: Dasar-dasar")
model LmsGroup {
  id        String      @id @default(cuid())
  program   Program     @relation(fields: [programId], references: [id], onDelete: Cascade)
  programId String
  title     String
  order     Int         @default(0)
  modules   LmsModule[]

  @@index([programId])
  @@map("lmsgroup")
}

// Modul / sub-bab — berisi materi; bisa berdiri sendiri atau di dalam kelompok
model LmsModule {
  id        String    @id @default(cuid())
  program   Program   @relation(fields: [programId], references: [id], onDelete: Cascade)
  programId String
  group     LmsGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)
  groupId   String?
  title     String
  order     Int       @default(0)
  lessons   Lesson[]

  @@index([programId])
  @@index([groupId])
  @@map("lmsmodule")
}

// LMS Lessons (Materi pembelajaran: video / teks / PDF / kuis)
model Lesson {
  id           String       @id @default(cuid())
  module       LmsModule    @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  moduleId     String
  title        String
  type         LessonType   @default(VIDEO)
  videoUrl     String? // URL Video YouTube / Vimeo
  fileUrl      String?      @db.Text // URL PDF (upload atau eksternal)
  content      String?      @db.Text // Teks materi pembelajaran
  duration     String       @default("10 menit") // Durasi materi
  passingScore Int? // khusus QUIZ: skor minimal lulus (null = pakai passingScore program)
  isPreview    Boolean      @default(false) // materi bisa diakses gratis sebagai preview
  order        Int          @default(0)
  questions    Question[] // soal kuis (khusus type QUIZ)
  completions  Completion[]

  @@index([moduleId])
  @@map("lesson")
}

// LMS Completions (Status selesai pengerjaan materi oleh peserta)
model Completion {
  id             String       @id @default(cuid())
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  registrationId String
  lesson         Lesson       @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  lessonId       String
  completedAt    DateTime     @default(now())

  @@unique([registrationId, lessonId])
  @@index([registrationId])
  @@index([lessonId])
  @@index([lessonId, registrationId]) // agregasi completion per pelajaran
  @@map("completion")
}

// OTP untuk login member — dikirim via WhatsApp, berlaku 5 menit
model OtpCode {
  id         String   @id @default(cuid())
  identifier String // whatsapp atau email — yang dipakai untuk login
  code       String // 6 digit angka
  used       Boolean  @default(false)
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@index([identifier])
  @@index([identifier, code]) // verifikasi OTP
  @@index([expiresAt]) // cleanup job: hapus OTP kedaluwarsa
  @@index([used, expiresAt]) // hapus OTP lama yang tidak terpakai
  @@map("otpcode")
}

// Kategori program
model Category {
  id         String    @id @default(cuid())
  slug       String    @unique
  name       String
  isFeatured Boolean   @default(false)
  programs   Program[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@map("category")
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
}

model User {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  whatsapp      String?        @unique
  institution   String?
  passwordHash  String? // Kata sandi terenkripsi (untuk ADMIN / TEACHER / STUDENT)
  role          Role           @default(STUDENT)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  registrations Registration[]

  @@index([role]) // filter by role di halaman user management
  @@index([createdAt]) // sort terbaru di daftar user
  @@map("user")
}

// API key untuk integrasi mesin-ke-mesin (mis. Hermes agent marketing) —
// bukan untuk login manusia. Dicek via header X-API-Key di /api/v1/*.
model ApiKey {
  id         String    @id @default(cuid())
  label      String    @default("Hermes Agent Marketing")
  key        String    @unique
  isActive   Boolean   @default(true)
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([key])
  @@map("apikey")
}

// Artikel blog — konten SEO, tidak tampil di beranda, hanya lewat menu & /artikel.
model Article {
  id            String    @id @default(cuid())
  slug          String    @unique
  title         String
  excerpt       String    @db.Text // ringkasan — dipakai di kartu daftar & meta description SEO
  content       String    @db.Text // HTML dari rich text editor, disanitasi sebelum simpan
  coverImageUrl String?   @db.Text
  authorName    String    @default("Tim Jetschool Academy")
  isPublished   Boolean   @default(false)
  publishedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([isPublished, publishedAt])
  @@map("article")
}
